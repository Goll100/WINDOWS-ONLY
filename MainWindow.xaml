<Window x:Class="ScholasticaReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Scholastica Reader" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <TextBlock Text="Library" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox x:Name="LibraryListBox" Height="Auto" DisplayMemberPath="Title"/>
                <Button Content="Open Book" Click="OpenBook_Click" Margin="0,10,0,0"/>
                <Button x:Name="TeacherDashboardBtn" Content="Teacher Dashboard" Click="TeacherDashboard_Click" Margin="0,5"/>
                <Button Content="Parallel Reading" Click="ParallelReading_Click" Margin="0,5"/>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="White">
            <wv2:WebView2 x:Name="BookWebView" />
        </Border>
        <Border Grid.Column="2" Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="1,0,0,0">
            <StackPanel Margin="10">
                <TextBlock Text="Annotations" FontSize="16" FontWeight="Bold"/>
                <ListBox x:Name="AnnotationsListBox" Height="200" DisplayMemberPath="Text"/>
                <TextBox x:Name="NoteTextBox" Height="80" TextWrapping="Wrap" Margin="0,10"/>
                <Button Content="Add Note" Click="AddNote_Click"/>
                <Button Content="Highlight" Click="Highlight_Click" Margin="0,5"/>
                <Button Content="TTS" Click="TTS_Click"/>
                <Button Content="Flashcards" Click="Flashcards_Click"/>
                <Button Content="Mind Map" Click="MindMap_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>                <Button Content="Mind Map" Click="MindMap_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>                <Button Content="Highlight" Click="Highlight_Click" Margin="0,5"/>
                <Button Content="TTS" Click="TTS_Click"/>
                <Button Content="Flashcards" Click="Flashcards_Click"/>
                <Button Content="Mind Map" Click="MindMap_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>                <Button Content="Highlight" Click="Highlight_Click" Margin="0,5"/>
                <Button Content="TTS" Click="TTS_Click"/>
                <Button Content="Flashcards" Click="Flashcards_Click"/>
                <Button Content="Mind Map" Click="MindMap_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
