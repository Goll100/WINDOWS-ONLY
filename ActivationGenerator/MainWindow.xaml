<Window x:Class="ActivationGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Code Generator" Height="300" Width="450">
    <StackPanel Margin="20">
        <TextBlock Text="Enter HWID:"/>
        <TextBox x:Name="HwidBox" Margin="0,5,0,15"/>
        <TextBlock Text="Days valid:"/>
        <TextBox x:Name="DaysBox" Text="7" Margin="0,5,0,15"/>
        <CheckBox x:Name="PremiumBox" Content="Premium License" Margin="0,0,0,15"/>
        <Button Content="Generate Code" Click="Generate_Click" Margin="0,0,0,20"/>
        <TextBlock Text="Activation Code:" FontWeight="Bold"/>
        <TextBox x:Name="CodeBox" IsReadOnly="True" TextWrapping="Wrap"/>
    </StackPanel>
</Window>
