<Window x:Class="ScholasticaReader.Views.FlashcardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flashcards" Height="400" Width="500">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20" Margin="20">
            <StackPanel>
                <TextBlock x:Name="QuestionText" Text="Question" FontSize="18" TextWrapping="Wrap" Margin="0,20"/>
                <Button Content="Show Answer" Click="ShowAnswer_Click" Margin="0,20"/>
                <TextBlock x:Name="AnswerText" Text="" FontSize="16" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <Button Content="Easy" Click="Easy_Click" Margin="5"/>
                    <Button Content="Hard" Click="Hard_Click" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
