<Window x:Class="ScholasticaReader.Views.MindMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mind Map" Height="500" Width="700">
    <Grid>
        <Canvas x:Name="MapCanvas" Background="White">
            <TextBlock Text="Central Idea" Canvas.Left="300" Canvas.Top="200" FontSize="20" FontWeight="Bold"/>
        </Canvas>
    </Grid>
</Window>
