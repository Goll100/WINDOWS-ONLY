<Window x:Class="ScholasticaReader.Views.ParallelReadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parallel Reading" Height="600" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <WebView2 x:Name="LeftWebView" Grid.Column="0" Margin="5"/>
        <WebView2 x:Name="RightWebView" Grid.Column="1" Margin="5"/>
    </Grid>
</Window> 
