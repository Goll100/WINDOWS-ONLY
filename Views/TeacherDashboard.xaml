<Window x:Class="ScholasticaReader.Views.TeacherDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher Dashboard" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Class Progress" FontSize="24" FontWeight="Bold"/>
            <DataGrid x:Name="ProgressGrid" AutoGenerateColumns="True" Margin="0,10"/>
            <Button Content="Assign Reading" Click="AssignReading_Click" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Window>
